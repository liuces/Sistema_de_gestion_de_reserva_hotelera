-- Crear la base de datos
CREATE DATABASE BDD_HOTEL;

-- Usar la base de datos
USE BDD_HOTEL;


-- CREACION DE TABLAS

CREATE TABLE HOTEL
(
    id_hotel NUMBER(5) NOT NULL,
    nombre_hotel VARCHAR2(20) NOT NULL,
    categoria_hotel VARCHAR2(20) NOT NULL,
    ciudad_hotel VARCHAR2(20) NOT NULL,
    direccion_hotel VARCHAR2(40) NOT NULL,
    CONSTRAINT PK_HOTEL PRIMARY KEY(id_hotel)
);   
CREATE TABLE CLIENTE (
    id_cliente NUMBER(5) NOT NULL,
    rut_cliente VARCHAR2(12) NOT NULL,
    nombre_cliente VARCHAR2(20) NOT NULL,
    ap_pat_cliente VARCHAR2(20) NOT NULL,
    ap_mat_cliente VARCHAR2(20) NOT NULL,
    correo_cliente VARCHAR2(50) NOT NULL,
    fono_cliente VARCHAR2(15) NOT NULL,
	CONSTRAINT PK_CLIENTE PRIMARY KEY(id_cliente)
);
CREATE TABLE EMPLEADO(
    id_empleado NUMBER(5) NOT NULL,
    rut_empleado VARCHAR2(12) NOT NULL,
    nombre_empleado VARCHAR2(20) NOT NULL,
    ap_pat_empleado VARCHAR2(20) NOT NULL,
    ap_mat_empleado VARCHAR2(20) NOT NULL,
    correo_empleado VARCHAR2(50) NOT NULL,
    fono_empleado VARCHAR2(15) NOT NULL,
	CONSTRAINT PK_EMPLEADO PRIMARY KEY(id_empleado)
);
CREATE TABLE HABITACION (
    id_habitacion NUMBER(6) NOT NULL,
    tipo_habitacion NUMBER(2) NOT NULL,
    capacidad_habitacion NUMBER(2) NOT NULL,
    precio_habitacion NUMBER(10) NOT NULL,
    CONSTRAINT PK_HABITACION PRIMARY KEY(id_habitacion)
);
CREATE TABLE RESERVA
(
    id_reserva NUMBER(6) NOT NULL,
    fecha_entrada DATE NOT NULL,
    fecha_salida DATE NOT NULL,
    cantidad_personas NUMBER(2) NOT NULL,
    CONSTRAINT PK_RESERVA PRIMARY KEY(id_reserva)
);
