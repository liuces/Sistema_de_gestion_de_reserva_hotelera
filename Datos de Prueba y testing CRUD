-- CONSULTAS DE VERIFICACIÓN CRUD
-- ============================================================
 
-- READ: Ver todas las reservas con datos del cliente y habitación
SELECT
    r.id_reserva,
    CONCAT(u.nombre_usuario, ' ', u.ap_pat_usuario) AS cliente,
    h.numero_habitacion,
    h.tipo_habitacion,
    r.fecha_entrada,
    r.fecha_salida,
    DATEDIFF(r.fecha_salida, r.fecha_entrada) AS noches,
    r.monto_total,
    r.estado_reserva
FROM RESERVA r
JOIN CLIENTE c ON r.id_cliente = c.id_cliente
JOIN USUARIO u ON c.id_usuario = u.id_usuario
JOIN HABITACION h ON r.id_habitacion = h.id_habitacion
ORDER BY r.fecha_entrada;
 
-- READ: Disponibilidad de habitaciones
SELECT
    numero_habitacion,
    tipo_habitacion,
    capacidad_habitacion,
    precio_habitacion,
    estado_habitacion
FROM HABITACION
WHERE id_hotel = 1
ORDER BY tipo_habitacion, precio_habitacion;
 
-- READ: Reporte de ingresos por reserva
SELECT
    r.id_reserva,
    CONCAT(u.nombre_usuario, ' ', u.ap_pat_usuario) AS cliente,
    r.monto_total AS total_reserva,
    p.monto_pagado AS pagado_30,
    p.metodo_pago,
    p.estado_pago
FROM RESERVA r
JOIN CLIENTE c ON r.id_cliente = c.id_cliente
JOIN USUARIO u ON c.id_usuario = u.id_usuario
JOIN PAGO p ON r.id_reserva = p.id_reserva
ORDER BY r.id_reserva;
 
